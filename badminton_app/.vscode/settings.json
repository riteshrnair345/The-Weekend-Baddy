{
  "faah.enabled": false,
  "faah.monitorTerminal": true,
  "faah.monitorDiagnostics": true,
  "faah.diagnosticsSeverity": "error",
  "faah.terminalDetectionMode": "either",
  "faah.cooldownMs": 500,
  "faah.terminalCooldownMs": 500,
  "faah.diagnosticsCooldownMs": 500,
  "faah.patternMode": "override",
  "faah.volumePercent": 95,
  "faah.showVisualNotifications": false,
  "faah.customSoundPath": "",
  "faah.quietHoursEnabled": false,
  "faah.quietHoursStart": "22:00",
  "faah.quietHoursEnd": "07:00",
  "faah.excludePresetIds": [],
  "faah.patterns": [
    "\\berror\\b",
    "\\bfailed\\b",
    "\\bfailure\\b",
    "\\bfatal\\b",
    "\\bexception\\b",
    "\\bcritical\\b",
    "\\berr(or)?[:!\\]]",
    "\\buncaught\\b",
    "UnhandledPromiseRejection",
    "Traceback \\(most recent call last\\):",
    "\\bsyntaxerror\\b",
    "\\btypeerror\\b",
    "\\breferenceerror\\b",
    "\\brangeerror\\b",
    "\\bmodule\\s+not\\s+found\\b",
    "\\bcannot\\s+find\\s+module\\b",
    "\\bno\\s+module\\s+named\\b",
    "\\bsegmentation\\s+fault\\b",
    "\\bcore\\s+dumped\\b",
    "\\bpanic:|\\bpanicked\\s+at\\b",
    "^\\s*caused\\s+by:",
    "\\bpermission\\s+denied\\b",
    "\\baccess\\s+denied\\b",
    "\\bcommand\\s+not\\s+found\\b",
    "\\btimeout(?:\\s+exceeded)?\\b",
    "\\bconnection\\s+(?:refused|reset|timed\\s*out)\\b",
    "\\bhttp\\s+5\\d\\d\\b"
  ],
  "faah.excludePatterns": [
    "^\\[[^\\]]+\\s[0-9a-f]{7,40}\\]\\s(?:feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(?:\\([^)]+\\))?!?:\\s.+$",
    "^(?:feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(?:\\([^)]+\\))?!?:\\s.+$"
  ]
}
